# Terraform state files – NEVER commit to git
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files (may contain secrets)
tfplan
*.tfplan

# Terraform init directories
.terraform/
.terraform.lock.hcl

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Variable files that may contain secrets
*.auto.tfvars
*.secret.tfvars
secrets.tfvars

# Terraform crash logs
crash.log
crash.*.log

# CLI configuration files
.terraformrc
terraform.rc

# OS artifacts
.DS_Store
Thumbs.db

# Editor artifacts
.idea/
.vscode/
*.swp
*.swo

# CI/CD output artifacts
tf_outputs.json
plan_output.txt
